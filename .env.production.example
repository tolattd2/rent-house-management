# =====================================================================
# Production env for the Synology NAS stack. Copy to .env.production and
# fill in real values. NEVER commit .env.production (it is gitignored).
# Both docker compose AND the app read this file.
# =====================================================================

# ---- Postgres (the DB container) ----
POSTGRES_USER=happyhome
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=happyhome

# ---- App: database connection (points at the postgres service) ----
# Host is the compose service name "postgres", reachable on the internal network.
DATABASE_URL=postgresql://happyhome:change-me-strong-password@postgres:5432/happyhome?schema=public

# ---- NextAuth ----
NEXTAUTH_URL=https://happyhomebyhas.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ---- App URLs ----
NEXT_PUBLIC_APP_URL=https://happyhomebyhas.com
NEXT_PUBLIC_APP_NAME=Happy Home

# ---- Object storage (MinIO, S3-compatible) ----
MINIO_ROOT_USER=happyhome
MINIO_ROOT_PASSWORD=change-me-strong-minio-password
# S3_ENDPOINT must be the PUBLIC MinIO hostname, NOT minio:9000 — the presigned
# upload URL is handed to the user's browser, which can only reach the tunnel host.
# Cloudflare Tunnel preserves the Host header, so the SigV4 signature validates.
# Tunnel maps media.happyhomebyhas.com -> minio:9000.
S3_ENDPOINT=https://media.happyhomebyhas.com
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=happyhome
S3_SECRET_ACCESS_KEY=change-me-strong-minio-password
S3_BUCKET=reminder-media
# Public base URL Telegram fetches finished media from (same host as S3_ENDPOINT).
S3_PUBLIC_URL=https://media.happyhomebyhas.com

# ---- Cloudflare Tunnel ----
# Token from: Cloudflare Zero Trust > Networks > Tunnels > (your tunnel) > Install connector.
CLOUDFLARE_TUNNEL_TOKEN=paste-tunnel-token-here

# ---- Cron (already enforced by the cron API routes) ----
CRON_SECRET=generate-another-random-secret

# ---- Telegram Bot ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Email (SMTP via nodemailer) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@happyhomebyhas.com

# ---- Optional: SMS (Twilio) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
